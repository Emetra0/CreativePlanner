{
  "name": "creative-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm --prefix backend run dev -- --local-protocol=http --port 8787",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "tauri": "tauri",
    "deploy:web": "npm run build && npx wrangler pages deploy dist --project-name creative-planner --branch main",
    "deploy:backend": "npm --prefix backend run deploy",
    "deploy:all": "npm run deploy:backend && npm run deploy:web"
  },
